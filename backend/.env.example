# Copy this file to .env and fill in your values.

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>

# ── Auth ─────────────────────────────────────────────────
SECRET_KEY=<generate with: openssl rand -hex 32>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── App ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Nomba ────────────────────────────────────────────────
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_ACCOUNT_ID=<your-nomba-account-id>
NOMBA_CLIENT_ID=<your-nomba-client-id>
NOMBA_CLIENT_SECRET=<your-nomba-client-secret>
NOMBA_WEBHOOK_SECRET=<your-nomba-webhook-secret>
NOMBA_HACKATHON_SUBACCOUNT=<your-nomba-subaccount-id>
NOMBA_CHECKOUT_CALLBACK_URL=http://localhost:3000/payment-success

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=<your-resend-api-key>
NOTIFICATION_EMAiL_FROM=onboarding@resend.dev

# ── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp content template SIDs
TWILIO_WHATSAPP_INVOICE_GENERATED_CONTENT_SID=<content-sid-for-invoice-generated>
TWILIO_WHATSAPP_PAYMENT_RECEIVED_CONTENT_SID=<content-sid-for-payment-received>

# ── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
